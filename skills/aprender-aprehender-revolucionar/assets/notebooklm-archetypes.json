  "uso": {
    "via_skill": "La skill aprender-aprehender-revolucionar invoca el arquetipo correcto según intent",
    "via_script": "python scripts/notebook_config_generator.py --arquetipo <id> [--variables...]",
    "via_copy_paste": "pbcopy < prompts/<archivo>.md · personalizar variables · pegar en NotebookLM Custom Goal"
  },
  "limites_notebooklm": {
    "max_chars_system_prompt": 10000,
    "ubicacion_config": "notebooklm.google.com → notebook → chat config → Custom Goal"
  }
